# Copy to .env and adjust as needed. .env is gitignored.

# HuggingFace cache lives next to the code so it survives across runs and is
# easy to wipe. Override to share with another project's HF cache.
HF_HOME=./.hf_cache

# Where the Ollama daemon listens. Default is fine on a local machine.
OLLAMA_HOST=http://127.0.0.1:11434

# Optional: force CPU even if a CUDA GPU is present (useful for low-RAM GPUs).
# Leave unset to auto-detect.
# FORCE_CPU=1
