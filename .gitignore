# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# IDEs and editors
.idea/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Project data — gitignored, regenerated by scripts
data/raw_pdfs/
data/chunks/*.jsonl
data/chunks/*.parsed.json
data/indexes/

# Diagnostic / debug dumps from running the pipeline manually
diag*.json
debug*.json
*.diag.json

# HuggingFace + local model caches
.hf_cache/
.cache/
/models/         # top-level only — do NOT match src/models/

# Eval outputs (drop everything inside the folder, with negations for
# documented samples we want to keep tracked)
eval/results/*
!eval/results/.gitkeep
!eval/results/sample_output.json
!eval/results/sample_output_plots/
# Judge result cache — local, regenerated on demand
eval/.judge_cache/

# Gradio runtime artifacts
gradio_cached_examples/
flagged/

# Notebook checkpoints
.ipynb_checkpoints/

# Local secrets / env
.env
.env.*
!.env.example

# Pytest / coverage / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Logs
*.log

# Internal docs (kept local, not published)
docs/
